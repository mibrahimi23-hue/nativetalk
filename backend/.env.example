# Copy to .env and fill in real values. Never commit Backend/.env.

# Runtime
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

# Database
# Local default:
DATABASE_URL=sqlite:///./nativetalk.db
# Docker example:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/myproject
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-dev-password
POSTGRES_DB=myproject
# Production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# JWT
# Generate with:
# python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# Google OAuth client IDs. These are public client IDs, not client secrets.
GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# PayPal
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_DEMO_MODE=true

# Daily.co video calls
DAILY_API_KEY=
DAILY_DOMAIN=

# CORS
# Use exact origins. Do not use "*" with credentials.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:8081

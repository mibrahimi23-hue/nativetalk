# Public base URL of the FastAPI backend (no trailing slash).
# If unset, the frontend auto-detects:
#   - On phone via Expo Go → http://<LAN-host-from-Expo>:8000
#   - Android emulator    → http://10.0.2.2:8000
#   - iOS simulator       → http://127.0.0.1:8000
#   - Web                 → http://localhost:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── Google OAuth (Continue with Google) ───────────────────────────────────────
# Web client ID is required (used to issue the ID token verified by the backend
# and as the default for Expo Go / web). Add platform-specific IDs for native
# builds so Google can route the sign-in to the correct OAuth app.
# Get the IDs from https://console.cloud.google.com → APIs & Services → Credentials.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=1089078582376-qi3fkb48jngsuftj3cvddohc3b1uhjrf.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
